# Default UCI Configuration for Telemt MTProxy (Headless Core) - v3.4.0
# This file provides the fallback values ensuring the LuCI WebUI renders correctly.

config telemt 'general'
	option enabled '0'
	option port '8443'
	option public_port ''
	option api_port '9091'
	option metrics_port '9092'
	# Control-plane bind addresses. 127.0.0.1 = loopback only (safe default).
	# Set 0.0.0.0 to expose on LAN (whitelist becomes the only guard).
	option metrics_listen_addr '127.0.0.1'
	option api_listen_addr '127.0.0.1'
	
	# Unified Control-Plane Switch (Replaces api_enabled & minimal_runtime_enabled)
	option extended_runtime_enabled '1'
	
	option metrics_allow_lo '1'
	option metrics_allow_lan '1'
	option metrics_whitelist ''
	option mode 'tls'
	option log_level 'normal'
	option domain 'google.com'
	option auto_fw '1'
	option listen_ipv4 '1'
	option listen_ipv6 '0'
	option prefer_ip '4'
	
	option use_middle_proxy '0'
	option use_stun '0'
	
	# Anti-censorship & TLS tuning defaults
	option mask_proxy_protocol '0'
	# 3.4.18
	option mask_dynamic '1'
	option client_mss ''
	# Self-Stealth: mask_port and mask_host redirect TLS probers to a local server
	option mask_port '443'
	option mask_host ''
	option fake_cert_len '2048'
	option tls_full_cert_ttl_secs '0'
	option replay_window_secs '1800'
	option ignore_time_skew '0'
	option desync_all_full '0'

	# Middle-End proxy limits
	option me_pool_size '16'
	option me_warm_standby '8'
	option hardswap '1'
	option me_drain_ttl '90'
	
	# Middle-End Adaptive Tuning (Hidden under UI spoiler)
					
	# Middle-End Outage Recovery
					
	# Fallback (Replaces auto_degradation_enabled)
	option auto_degradation '1'
	option degradation_min_dc '2'
	
	# Custom user scripts/bot update interval
	option update_every '300'
